    hideLoading();

    // 저장된 출고일이 있으면 자동 적용
    const hasDate = savedDates.some(d => d && d.trim());
    if (hasDate && (orderDataOriginal.length > 0 || orderDataBuy.length > 0)) {
        applyDates();
    }
}

init();
