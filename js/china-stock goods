// =========================================================
// 전역 상태
// =========================================================
let orderDataOriginal = []; // 오더리스트(원본) 파싱 결과
let orderDataBuy = [];      // 오더리스트(사입) 파싱 결과
let stockLogData = {};      // 미발재고로그 { 상품코드: { ... } }
let tableData = [];         // 최종 테이블에 표시할 데이터
let filteredData = [];      // 검색 필터된 데이터
