    showLoading('🔄 오더리스트를 시트에서 가져오는 중...');
    try {
        let countOrder = 0, countBuy = 0;
        if (csvUrlOrder) {
            const data = await fetchCSV(csvUrlOrder);
            orderDataOriginal = data;
            await saveChunkedData(data, 'Order');
            countOrder = data.length;
        }
