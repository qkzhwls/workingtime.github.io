    } catch (e) {
        hideLoading();
        alert('🚨 동기화 실패: ' + e.message);
    }
};

// =========================================================
// 미발재고로그 업로드 (.xls = HTML table 형식)
// =========================================================
function setupUploadHandler() {
    document.getElementById('upload-stock-log')?.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        showLoading('📂 미발재고로그 분석 중...');

        try {
            const text = await file.text();
            let rows = [];

            // HTML table 형식 감지
            if (text.trim().startsWith('<') || text.includes('<table') || text.includes('<html')) {
                const parser = new DOMParser();
                const htmlDoc = parser.parseFromString(text, 'text/html');
                const table = htmlDoc.querySelector('table');
                if (!table) throw new Error('HTML 내에서 테이블을 찾을 수 없습니다.');

                const trs = table.querySelectorAll('tr');
                let headers = [];
                trs.forEach((tr, idx) => {
                    const cells = tr.querySelectorAll('td, th');
                    const vals = Array.from(cells).map(c => c.textContent.trim());
                    if (idx === 0) {
                        headers = vals;
                    } else {
                        let obj = {};
                        vals.forEach((v, j) => { if (headers[j]) obj[headers[j]] = v; });
                        if (obj['상품코드']) rows.push(obj);
                    }
                });
            } else {
                // 일반 엑셀
                const ab = await file.arrayBuffer();
                const wb = XLSX.read(ab, { type: 'array' });
                const raw = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { defval: '' });
                rows = raw.filter(r => r['상품코드']);
            }

            // 메모리에 저장
            stockLogData = {};
            rows.forEach(row => {
                const code = (row['상품코드'] || '').toString().trim();
                if (code) stockLogData[code] = row;
            });

            // Firebase에 저장
            await saveChunkedData(rows, 'StockLog');

            hideLoading();
            showToast(`✅ 미발재고로그 ${rows.length}건 업로드 완료`);

            // 테이블 재생성
            if (tableData.length > 0) buildTableFromData();

        } catch (err) {
            hideLoading();
            alert('🚨 파일 파싱 실패: ' + err.message);
            console.error(err);
        }
        e.target.value = '';
    });
}

// =========================================================
// 출고일 적용 → 테이블 생성
// =========================================================
window.applyDates = function() {
    const inputDates = [];
    for (let i = 1; i <= 8; i++) {
        const val = document.getElementById(`date-${i}`)?.value;
        if (val) inputDates.push(normalizeDate(val));
    }
    if (inputDates.length === 0) {
        alert('출고일을 1개 이상 입력해주세요.');
        return;
    }

    saveConfig(); // 출고일 Firebase에 저장

    // 오더리스트(원본)에서 매칭
    // 출고일 컬럼: 1차~6차 패킹리스트 출고일
    const dateColsOriginal = ['1차패킹리스트출고일', '2차패킹리스트출고일', '3차패킹리스트출고일', '4차패킹리스트출고일', '5차패킹리스트출고일', '6차패킹리스트출고일'];
    const qtyColsOriginal = ['1차패킹리스트출고수량', '2차패킹리스트출고수량', '3차패킹리스트출고수량', '4차패킹리스트출고수량', '5차패킹리스트출고수량', '6차패킹리스트출고수량'];

    // 오더리스트(사입)에서 매칭
    const dateColsBuy = ['1차패킹리스트출고일', '2차패킹리스트출고일'];
    const qtyColsBuy = ['1차패킹리스트출고수량', '2차패킹리스트출고수량'];

    // 결과 수집: { 상품코드: { name, option, arrivalQty, bigoY } }
    let resultMap = {};

    // 원본 스캔
    orderDataOriginal.forEach(row => {
        const code = (row['어드민상품코드'] || row['상품코드'] || '').toString().trim();
        if (!code) return;

        let matched = false;
        let totalQty = 0;

        dateColsOriginal.forEach((dateCol, idx) => {
            const rawDate = normalizeDate(row[dateCol] || '');
            if (rawDate && inputDates.includes(rawDate)) {
                matched = true;
                const qty = parseInt(row[qtyColsOriginal[idx]]) || 0;
                totalQty += qty;
            }
        });

        if (matched) {
            if (!resultMap[code]) {
                resultMap[code] = {
                    code,
                    name: row['상품명'] || '',
                    option: row['옵션'] || '',
                    arrivalQty: 0,
                    bigoY: row['비고'] || ''
                };
            }
            resultMap[code].arrivalQty += totalQty;
        }
    });

    // 사입 스캔
    orderDataBuy.forEach(row => {
        const code = (row['어드민상품코드'] || row['상품코드'] || '').toString().trim();
        if (!code) return;

        let matched = false;
        let totalQty = 0;

        dateColsBuy.forEach((dateCol, idx) => {
            const rawDate = normalizeDate(row[dateCol] || '');
            if (rawDate && inputDates.includes(rawDate)) {
                matched = true;
                const qty = parseInt(row[qtyColsBuy[idx]]) || 0;
                totalQty += qty;
            }
        });

        if (matched) {
            if (!resultMap[code]) {
                resultMap[code] = {
                    code,
                    name: row['상품명'] || '',
                    option: row['옵션'] || '',
                    arrivalQty: 0,
                    bigoY: ''
                };
            }
            resultMap[code].arrivalQty += totalQty;
        }
    });

    // 미발재고로그 매칭
    tableData = Object.values(resultMap).map(item => {
        const log = stockLogData[item.code] || {};
        const loc = (log['로케이션'] || '').toString().split('/')[0].trim();
        const totalStock = parseInt(log['정상재고']) || 0;
        const mibalQty = parseInt(log['부족수량']) || 0;
        const capacity = getCapacityByLocation(loc);

        // 편집된 값 복원
        const edited = editedCells[item.code] || {};

        return {
            code: item.code,
            name: item.name,
            option: item.option,
            arrivalQty: item.arrivalQty,
            mibalQty,
            totalStock,
            location: loc,
            capacity,
            confirmed: edited.confirmed || '',
            shortage: edited.shortage || '',
            directShip: item.bigoY || edited.directShip || '',
            memo: edited.memo || ''
        };
    });

    // 도착수량 0인 항목 제외
    tableData = tableData.filter(d => d.arrivalQty > 0);

    filteredData = [...tableData];
    renderTable();
    updateSummary();
    showToast(`✅ ${tableData.length}개 상품 매칭 완료`);
};

window.clearDates = function() {
    for (let i = 1; i <= 8; i++) {
        const el = document.getElementById(`date-${i}`);
        if (el) el.value = '';
    }
    tableData = [];
    filteredData = [];
    renderTable();
    updateSummary();
    saveConfig();
};

// =========================================================
// 테이블 렌더링
// =========================================================
function renderTable() {
    const tbody = document.getElementById('table-body');
    if (!filteredData || filteredData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="13" style="text-align:center; padding:50px; color:#888;">표시할 데이터가 없습니다.</td></tr>';
        return;
    }

    let html = '';
    filteredData.forEach((row, idx) => {
        html += `<tr>
            <td style="color:#888; font-size:12px;">${idx + 1}</td>
            <td class="code-cell" onclick="copyCode('${row.code}')">${row.code}</td>
            <td style="text-align:left; padding-left:10px;">${row.name}</td>
            <td style="font-size:12px;">${row.option}</td>
            <td style="font-weight:bold;">${row.arrivalQty.toLocaleString()}</td>
            <td style="font-weight:bold; color:${row.mibalQty > 0 ? '#d32f2f' : '#333'};">${row.mibalQty.toLocaleString()}</td>
            <td>${row.totalStock.toLocaleString()}</td>
            <td style="font-size:12px;">${row.location}</td>
            <td class="capacity-auto">${row.capacity || '-'}</td>
            <td class="editable-cell" contenteditable="true" data-code="${row.code}" data-field="confirmed" onblur="onCellEdit(this)">${row.confirmed}</td>
            <td class="editable-cell" contenteditable="true" data-code="${row.code}" data-field="shortage" onblur="onCellEdit(this)">${row.shortage}</td>
            <td class="editable-cell" contenteditable="true" data-code="${row.code}" data-field="directShip" onblur="onCellEdit(this)">${row.directShip}</td>
            <td class="editable-cell" contenteditable="true" data-code="${row.code}" data-field="memo" onblur="onCellEdit(this)">${row.memo}</td>
        </tr>`;
    });
    tbody.innerHTML = html;
}

function buildTableFromData() {
    // 미발재고로그가 새로 업로드되었을 때 기존 테이블 데이터 갱신
    tableData.forEach(item => {
        const log = stockLogData[item.code] || {};
        const loc = (log['로케이션'] || '').toString().split('/')[0].trim();
        item.totalStock = parseInt(log['정상재고']) || 0;
        item.mibalQty = parseInt(log['부족수량']) || 0;
        item.location = loc;
        item.capacity = getCapacityByLocation(loc);
    });
    filteredData = [...tableData];
    applySearch();
    renderTable();
    updateSummary();
}

function updateSummary() {
    document.getElementById('sum-sku').textContent = filteredData.length.toLocaleString();
    document.getElementById('sum-arrival').textContent = filteredData.reduce((s, d) => s + (d.arrivalQty || 0), 0).toLocaleString();
    document.getElementById('sum-mibal').textContent = filteredData.reduce((s, d) => s + (d.mibalQty || 0), 0).toLocaleString();
}

// =========================================================
// 셀 편집 → 자동 저장
// =========================================================
let saveTimeout = null;
window.onCellEdit = function(el) {
    const code = el.dataset.code;
    const field = el.dataset.field;
    const value = el.textContent.trim();

    if (!editedCells[code]) editedCells[code] = {};
    editedCells[code][field] = value;

    // 로컬 데이터도 갱신
    const item = tableData.find(d => d.code === code);
    if (item) item[field] = value;

    // 디바운스 저장 (1초 후)
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(() => {
        saveEditedCells();
        showToast('💾 자동 저장됨');
    }, 1000);
};

// =========================================================
// 검색
// =========================================================
window.applySearch = function() {
    const keyword = (document.getElementById('search-input')?.value || '').trim().toUpperCase();
    if (!keyword) {
        filteredData = [...tableData];
    } else {
        filteredData = tableData.filter(d =>
            d.code.toUpperCase().includes(keyword) ||
            d.name.toUpperCase().includes(keyword) ||
            d.option.toUpperCase().includes(keyword)
        );
    }
    renderTable();
    updateSummary();
};

// =========================================================
// 정렬
// =========================================================
window.sortTable = function(key) {
    if (sortConfig.key === key) {
        sortConfig.direction = sortConfig.direction === 'asc' ? 'desc' : 'asc';
    } else {
        sortConfig.key = key;
        sortConfig.direction = 'asc';
    }

    filteredData.sort((a, b) => {
        let va = a[key], vb = b[key];
        if (typeof va === 'number' && typeof vb === 'number') {
            return sortConfig.direction === 'asc' ? va - vb : vb - va;
        }
        va = (va || '').toString();
        vb = (vb || '').toString();
        return sortConfig.direction === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
    });
    renderTable();
};

